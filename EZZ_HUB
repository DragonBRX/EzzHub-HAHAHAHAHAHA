local function RegisterButtonClick(btn)
    -- Ignora a propria UI do EZZ
    if btn:FindFirstAncestorWhichIsA("ScreenGui") then
        local sg = btn:FindFirstAncestorWhichIsA("ScreenGui")
        if sg and sg.Name == "EZZ_Compact" then return end
    end

    local rawText = btn.Text ~= "" and btn.Text or btn.Name
    local decodedText, decodeMethod = TryDecryptText(rawText)

    local entry = {
        Name   = btn.Name,
        Text   = decodedText,
        RawText = rawText,
        DecodeMethod = decodeMethod,
        Parent = btn.Parent and btn.Parent.Name or "?",
        Time   = os.date("%H:%M:%S"),
        State  = CurrentState,
    }

    -- Evita duplicatas consecutivas do mesmo botao no mesmo segundo
    local last = PlayerInteractions.ClickedButtons[#PlayerInteractions.ClickedButtons]
    if last and last.Name == entry.Name and last.Time == entry.Time then return end

    if #PlayerInteractions.ClickedButtons >= Config.MaxClicks then
        table.remove(PlayerInteractions.ClickedButtons, 1)
    end

    TouchDirectInteraction()
    table.insert(PlayerInteractions.ClickedButtons, entry)

    ClickCount = ClickCount + 1
    if #RecordingData.Interactions.Clicks >= Config.MaxClicks then
        table.remove(RecordingData.Interactions.Clicks, 1)
    end

    local targetKey = entry.Parent .. "/" .. entry.Name
    table.insert(RecordingData.Interactions.Clicks, {
        ID = ClickCount,
        Type = "UI_BUTTON",
        Target = entry.Text,
        RawTarget = entry.RawText,
        DecodeMethod = entry.DecodeMethod,
        Name = entry.Name,
        Parent = entry.Parent,
        State = entry.State,
        Time = entry.Time
    })
    RecordingData.Interactions.Summary.UniqueTargets[targetKey] = true
    RecordingData.Interactions.Summary.TotalClicks = ClickCount

    AddToTimeline("BTN_CLICK", { Button = entry.Text, State = entry.State })
    Log("[CLICK] Botao clicado: [" .. entry.Text .. "] em " .. entry.Parent)
end

-- Conecta listener em todos os botoes do PlayerGui (exceto EZZ)
local HookedButtons = {}

local function HookAllButtons()
    local gui = LocalPlayer.PlayerGui
    for _, obj in pairs(gui:GetDescendants()) do
        if obj:IsA("TextButton") or obj:IsA("ImageButton") then
            if not HookedButtons[obj] then
                local sg = obj:FindFirstAncestorWhichIsA("ScreenGui")
                if sg and sg.Name ~= "EZZ_Compact" then
                    HookedButtons[obj] = SafeConnect(obj.MouseButton1Click, function()
                        RegisterButtonClick(obj)
                    end)
                end
            end
        end
    end
end

-- Re-hookeia quando novos objetos aparecem (menus que abrem depois)
local function WatchForNewButtons()
    local gui = LocalPlayer.PlayerGui
    SafeConnect(gui.DescendantAdded, function(obj)
        task.wait(0.05) -- espera o objeto estar pronto
        if (obj:IsA("TextButton") or obj:IsA("ImageButton")) and not HookedButtons[obj] then
            local sg = obj:FindFirstAncestorWhichIsA("ScreenGui")
            if sg and sg.Name ~= "EZZ_Compact" then
                HookedButtons[obj] = SafeConnect(obj.MouseButton1Click, function()
                    RegisterButtonClick(obj)
                end)
            end
        end
    end)

    -- Limpa conexoes de objetos removidos
    SafeConnect(gui.DescendantRemoving, function(obj)
        if HookedButtons[obj] then
            HookedButtons[obj]:Disconnect()
            HookedButtons[obj] = nil
        end
    end)
end

-- Captura teclas premidas pelo jogador (movimento, acoes)
local function MonitorKeys()
    SafeConnect(UserInputService.InputBegan, function(input, gameProcessed)
        -- Ignora se foi capturado pelo jogo (ex: chat)
        if gameProcessed then return end

        if Config.EnableUiToggleHotkey and input.KeyCode == Config.UiToggleKey then
            local gui = LocalPlayer.PlayerGui:FindFirstChild("EZZ_Compact")
            if gui then
                gui.Enabled = not gui.Enabled
            end
            return
        end

        local keyName = input.KeyCode.Name
        -- Filtra teclas irrelevantes (movimentos comuns)
        local ignore = { W=true, A=true, S=true, D=true, Space=true, LeftShift=true }
        if ignore[keyName] then return end

        if #PlayerInteractions.KeysPressed >= 50 then
            table.remove(PlayerInteractions.KeysPressed, 1)
        end

        TouchDirectInteraction()
        table.insert(PlayerInteractions.KeysPressed, {
            Key   = keyName,
            Time  = os.date("%H:%M:%S"),
            State = CurrentState,
        })

        AddToTimeline("KEY", { Key = keyName, State = CurrentState })
        Log("[KEY] Tecla: " .. keyName)
    end)
end

