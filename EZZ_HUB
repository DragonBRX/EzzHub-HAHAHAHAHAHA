end

local function IsInsideDirectInteractionWindow()
    return (os.clock() - LastDirectInteractionAt) <= Config.RemoteInteractionWindow
end

local function IsInsideObservableInteractionWindow()
    return (os.clock() - LastDirectInteractionAt) <= Config.ObservableInteractionWindow
end

local function IsInsidePlayerContainerWindow()
