local function MonitorRemotes()
    if not hookmetamethod or not getnamecallmethod then
        Log("[WARN] Hook de remotes indisponivel neste executor")
        return
    end

    local function RegisterRemoteCall(remote, method, args, argCount, shouldRecord, returnValue, hasReturn)
        local ok, err = pcall(function()
            if not shouldRecord then return end

            RemoteCount = RemoteCount + 1
            if #RecordingData.Interactions.RemoteCalls >= Config.MaxRemoteCalls then
                table.remove(RecordingData.Interactions.RemoteCalls, 1)
            end

            local remoteName, decodeMethod = TryDecryptText(remote.Name)
            local entry = {
                ID = RemoteCount,
                Remote = remoteName,
                RawRemote = remote.Name,
                DecodeMethod = decodeMethod,
                Method = method,
                Path = GetObjectPath(remote),
                ArgCount = argCount,
                Args = SerializeRemoteArgs(args, argCount),
                RemoteTree = BuildRemoteTree(remote),
                RemoteContext = BuildRemoteContext(remote),
                Time = os.date("%H:%M:%S"),
                State = CurrentState
            }

            if hasReturn then
                entry.Return = SerializeRemoteArg(returnValue, 0)
            end

            table.insert(RecordingData.Interactions.RemoteCalls, entry)
            RecordingData.Interactions.Summary.TotalRemotes = RemoteCount
            AddToTimeline("REMOTE", {Name = remoteName, Method = method})

            if hasReturn then
                AddToTimelineDebounced("REMOTE_INVOKE_RETURN", {
                    Remote = remoteName,
                    Result = entry.Return
                }, {GetObjectPath(remote), "return"}, Config.DebounceCooldown)
            end
        end)

        if not ok then
            Log("[WARN] Falha ao registrar remote: " .. tostring(err))
        end
    end

    local ok, err = pcall(function()
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()

            -- Sempre chama o original primeiro para garantir que nada é bloqueado
            local result = table.pack(oldNamecall(self, ...))

            if typeof(self) == "Instance" then
                if self == HttpService and Config.EnableHttpHooks and (method == "GetAsync" or method == "PostAsync" or method == "RequestAsync") then
                    local argCount = select("#", ...)
                    local args = {...}
                    SafeDefer(RegisterHttpCall, method, args, argCount, result[1])
                end

                local isRemoteEvent = method == "FireServer" and self:IsA("RemoteEvent")
                local isRemoteFunction = method == "InvokeServer" and self:IsA("RemoteFunction")

                if isRemoteEvent then
                    local argCount = select("#", ...)
                    local args = {...}
                    local shouldRecord = not Config.DirectInteractionOnly or IsInsideDirectInteractionWindow()
                    SafeDefer(RegisterRemoteCall, self, method, args, argCount, shouldRecord, nil, false)
                elseif isRemoteFunction then
                    local argCount = select("#", ...)
                    local args = {...}
                    local shouldRecord = not Config.DirectInteractionOnly or IsInsideDirectInteractionWindow()
                    if Config.EnableRemoteReturnCapture then
                        SafeDefer(RegisterRemoteCall, self, method, args, argCount, shouldRecord, result[1], true)
                    else
                        SafeDefer(RegisterRemoteCall, self, method, args, argCount, shouldRecord, nil, false)
                    end
                end
            end

            return table.unpack(result, 1, result.n)
        end)
    end)

    if not ok then
        Log("[WARN] Falha ao ativar hook de remotes: " .. tostring(err))
    end
end

