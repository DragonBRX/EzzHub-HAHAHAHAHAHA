local function SanitizeFileName(value)
    local text = tostring(value or "")
    text = text:gsub("[%z%c]", "")
    text = text:gsub("[<>:\"/\\|%?%*]", "_")
    text = text:gsub("^%s+", ""):gsub("%s+$", "")
    text = text:gsub("%s+", " ")
    if text == "" then text = "sem_nome" end
    if #text > 80 then text = text:sub(1, 80) end
    return text
end

local function SplitPath(path)
    local parts = {}
    for part in tostring(path or ""):gmatch("[^%.]+") do
        table.insert(parts, part)
    end
    return parts
end

local function EnsureFolder(path)
    if not makefolder then
        return false, "makefolder indisponivel neste executor"
    end
    local current = ""
    for part in tostring(path):gmatch("[^/]+") do
        current = current == "" and part or (current .. "/" .. part)
        local ok = pcall(function()
            if isfolder then
                if not isfolder(current) then
                    makefolder(current)
                end
            else
                -- Sem isfolder, tenta criar e ignora erro de pasta ja existente.
                pcall(function()
                    makefolder(current)
                end)
            end
        end)
        if not ok then
            return false, "falha ao criar pasta: " .. current
        end
    end
    return true
end

local function GetSafeGameName()
    local name = nil
    pcall(function()
        local info = MarketplaceService:GetProductInfo(game.PlaceId)
        if info and type(info.Name) == "string" and info.Name ~= "" then
            name = info.Name
        end
    end)
    if not name or name == "" then
        pcall(function() name = game.Name end)
    end
    if not name or name == "" then
        name = "Place_" .. tostring(game.PlaceId)
    end
    return SanitizeFileName(name)
end

local function GetScriptExtension(className)
    if className == "LocalScript" then return ".client.lua" end
    if className == "ModuleScript" then return ".module.lua" end
    if className == "Script" then return ".server.lua" end
    return ".lua"
end

local function BuildScriptFilePath(baseFolder, entry, usedPaths)
    local parts = SplitPath(entry.Path or entry.Name or ("script_" .. tostring(entry.ID)))
    local folder = baseFolder

    if #parts > 1 then
        for i = 1, #parts - 1 do
            folder = folder .. "/" .. SanitizeFileName(parts[i])
        end
    else
        folder = folder .. "/SemPasta"
    end

    local ok, err = EnsureFolder(folder)
    if not ok then return nil, err end

    local baseName = SanitizeFileName(entry.Name or parts[#parts] or ("script_" .. tostring(entry.ID)))
    local extension = GetScriptExtension(entry.ClassName)
    local filePath = folder .. "/" .. baseName .. extension

    if usedPaths[filePath] then
        filePath = folder .. "/" .. baseName .. "_" .. tostring(entry.ID or usedPaths[filePath] + 1) .. extension
    end
    usedPaths[filePath] = true
    return filePath
end

local function BuildFlatScriptFileName(entry, usedNames, stamp)
    local id = tonumber(entry.ID) or 0
    local source = SanitizeFileName(entry.Source or "Local")
    local scriptName = SanitizeFileName(entry.Name or ("script_" .. tostring(id)))
    local className = tostring(entry.ClassName or "Script")
    local extension = GetScriptExtension(className)

    -- Mantem o nome do script visivel e coloca ID na frente para nao sobrescrever.
    local fileName = string.format("%03d_%s_%s%s", id, source, scriptName, extension)
    if usedNames[fileName] then
        fileName = string.format("%03d_%s_%s_%s%s", id, source, scriptName, stamp, extension)
    end
    usedNames[fileName] = true
    return fileName
end

SaveCapturedScriptsToFiles = function()
    if not writefile then
        return { Ok = false, Error = "writefile indisponivel neste executor" }
    end

    local scripts = RecordingData.Interactions.CapturedScripts or {}
    if #scripts == 0 then
        return { Ok = false, Error = "nenhum codigo capturado" }
    end

    local stamp = os.date("%Y%m%d_%H%M%S")
    local gameName = GetSafeGameName()
    local rootFolder = tostring(Config.ScriptSaveRootFolder or "EZZ_CapturedCodes")
    local baseFolder = rootFolder .. "/" .. gameName

    -- Criacao simples: raiz + pasta do jogo. Evita varias subpastas profundas, porque muitos executores falham nisso.
    local okRoot, errRoot = EnsureFolder(rootFolder)
    if not okRoot then
        return { Ok = false, Error = errRoot }
    end

    local okFolder, errFolder = EnsureFolder(baseFolder)
    if not okFolder then
        return { Ok = false, Error = errFolder }
    end

    local manifest = {
        GameName = gameName,
        PlaceId = game.PlaceId,
        PlayerName = LocalPlayer.Name,
        SavedAt = os.date("%Y-%m-%d %H:%M:%S"),
        Folder = baseFolder,
        Mode = "flat_files_no_deep_subfolders",
        TotalCaptured = #scripts,
        TotalSaved = 0,
        TotalMetadataOnly = 0,
        TotalErrors = 0,
        Files = {},
    }

    local usedNames = {}

    for _, entry in ipairs(scripts) do
        local code = entry.Code
        local savedRawFallback = false

        if (type(code) ~= "string" or code == "") and type(entry.RawCode) == "string" and entry.RawCode ~= "" then
            code = entry.RawCode
            savedRawFallback = true
        end

        if type(code) == "string" and code ~= "" then
            local fileName = BuildFlatScriptFileName(entry, usedNames, stamp)
            local filePath = baseFolder .. "/" .. fileName
            local okWrite, writeErr = pcall(function()
                writefile(filePath, code)
            end)

            if okWrite then
                manifest.TotalSaved = manifest.TotalSaved + 1
                table.insert(manifest.Files, {
                    ID = entry.ID,
                    Name = entry.Name,
                    ClassName = entry.ClassName,
                    Path = entry.Path,
                    Source = entry.Source,
                    File = filePath,
                    FileName = fileName,
                    SourceReadable = entry.SourceReadable,
                    DecodeMethod = entry.DecodeMethod,
                    Encrypted = entry.Encrypted,
                    CodeLength = entry.CodeLength,
                    RawCodeLength = entry.RawCodeLength,
                    CodeTruncated = entry.CodeTruncated,
                    SavedRawFallback = savedRawFallback,
                    SuspiciousFlags = entry.SuspiciousFlags,
                })
            else
                manifest.TotalErrors = manifest.TotalErrors + 1
                table.insert(manifest.Files, {
                    ID = entry.ID,
                    Name = entry.Name,
                    ClassName = entry.ClassName,
                    Path = entry.Path,
                    Source = entry.Source,
                    Error = tostring(writeErr),
                })
            end
        else
            manifest.TotalMetadataOnly = manifest.TotalMetadataOnly + 1
            table.insert(manifest.Files, {
                ID = entry.ID,
                Name = entry.Name,
                ClassName = entry.ClassName,
                Path = entry.Path,
                Source = entry.Source,
                SourceReadable = entry.SourceReadable,
                SourceReadStatus = entry.SourceReadStatus,
                Note = entry.Note,
                MetadataOnly = true,
            })
        end
    end

    local manifestPath = baseFolder .. "/manifest_" .. stamp .. ".json"
    local fullJsonPath = baseFolder .. "/captured_codes_full_" .. stamp .. ".json"

    local okManifest, errManifest = pcall(function()
        writefile(manifestPath, HttpService:JSONEncode(manifest))
    end)

    local okFull, errFull = pcall(function()
        writefile(fullJsonPath, HttpService:JSONEncode(scripts))
    end)

    if not okManifest then
        manifest.TotalErrors = manifest.TotalErrors + 1
        Log("[CODIGOS] Falha ao salvar manifest: " .. tostring(errManifest))
    end
    if not okFull then
        manifest.TotalErrors = manifest.TotalErrors + 1
        Log("[CODIGOS] Falha ao salvar JSON completo: " .. tostring(errFull))
    end

    AddToTimeline("CODE_SAVE_FILES", {
        Folder = baseFolder,
        Saved = manifest.TotalSaved,
        MetadataOnly = manifest.TotalMetadataOnly,
        Errors = manifest.TotalErrors,
    })

    return {
        Ok = manifest.TotalSaved > 0,
        Folder = baseFolder,
        Manifest = okManifest and manifestPath or nil,
        FullJson = okFull and fullJsonPath or nil,
        SavedCount = manifest.TotalSaved,
        MetadataOnly = manifest.TotalMetadataOnly,
        ErrorCount = manifest.TotalErrors,
        Error = manifest.TotalSaved > 0 and nil or "nenhum codigo com Source/RawCode legivel foi salvo; manifest/json ainda podem ter sido criados",
    }
end

