        ClassName = scriptObject.ClassName,
        Path = GetObjectPath(scriptObject),
        Attributes = GetAttributesSnapshot(scriptObject),
        Tags = GetTagsSnapshot(scriptObject),
        SourceReadable = false,
        Note = "Script encontrado como instancia; Source nao fica disponivel para leitura normal em runtime.",
    }
end

local function BuildRemoteContext(remote)
    local context = {
        Ancestors = {},
        NearbyValues = {},
        NearbyScripts = {},
    }

    local ancestor = remote.Parent
    local ancestorDepth = 0
    while ancestor and ancestorDepth < Config.MaxRemoteAncestorDepth do
        ancestorDepth = ancestorDepth + 1
        table.insert(context.Ancestors, BuildRemoteSummary(ancestor))
        ancestor = ancestor.Parent
    end

    local contextRoot = remote.Parent
    if contextRoot then
        local valueCount = 0
        local scriptCount = 0

        for _, descendant in ipairs(contextRoot:GetDescendants()) do
            if descendant:IsA("ValueBase") then
                valueCount = valueCount + 1
                if valueCount > Config.MaxRemoteContextValues then
                    context.NearbyValuesTruncated = true
                else
                    table.insert(context.NearbyValues, BuildValueSummary(descendant))
                end
            elseif descendant:IsA("LuaSourceContainer") then
                scriptCount = scriptCount + 1
                if scriptCount > Config.MaxRemoteContextScripts then
                    context.NearbyScriptsTruncated = true
                else
                    table.insert(context.NearbyScripts, BuildScriptSummary(descendant))
                end
            end

            if context.NearbyValuesTruncated and context.NearbyScriptsTruncated then
                break
            end
        end
    end

    return context
end

function GetObjectPath(obj)
    local ok, path = pcall(function()
        return obj:GetFullName()
    end)
    return ok and path or obj.Name
end

local function GetObjectPosition(obj)
    if obj:IsA("BasePart") then
        return SerializeValue(obj.Position)
    end
    if obj:IsA("Model") then
        local ok, pivot = pcall(function()
            return obj:GetPivot()
        end)
        if ok then
            return SerializeValue(pivot.Position)
        end
    end
    return nil
end

function GetAttributesSnapshot(obj)
    local attributes = {}
    local ok, source = pcall(function()
        return obj:GetAttributes()
    end)
    if not ok then return attributes end

    for key, value in pairs(source) do
        attributes[key] = SerializeValue(value)
    end
    return attributes
end

local function KeyLooksLikeIdentifier(key)
    local lowerKey = tostring(key):lower()
    for _, pattern in ipairs(IdentifierKeyPatterns) do
        if lowerKey:find(pattern, 1, true) then
            return true
        end
    end
    return false
end

local function NameLooksInteresting(name)
    local lowerName = tostring(name):lower()
    for _, pattern in ipairs(InterestingNamePatterns) do
        if lowerName:find(pattern, 1, true) then
            return true
        end
    end
    return false
end

local function ExtractIdentifiersFromAttributes(attributes)
    local identifiers = {}
    for key, value in pairs(attributes) do
        if KeyLooksLikeIdentifier(key) then
            identifiers[key] = value
        end
    end
    return identifiers
end

local function ExtractIdentifiersFromValueObject(obj)
    if not obj:IsA("ValueBase") then return {} end
    if not KeyLooksLikeIdentifier(obj.Name) and not NameLooksInteresting(obj.Name) then return {} end

    return {
        [obj.Name] = SerializeValue(obj.Value)
    }
end

local function ExtractIdentifiersFromText(label, text)
    local identifiers = {}
    if type(text) ~= "string" or text == "" then return identifiers end

    local uuid = text:match("%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x")
    if uuid then
        identifiers[label .. "UUID"] = uuid
    end

    local longNumber = text:match("%f[%d]%d%d%d%d%d%d%d%d%d+%f[%D]")
    if longNumber then
        identifiers[label .. "NumericId"] = longNumber
    end

    local composite = text:match("[%w]+_[%w%-]+")
    if composite and (#composite >= 12 or composite:find("%-")) then
        identifiers[label .. "CompositeId"] = composite
    end

    return identifiers
end

local function MergeIdentifiers(target, source)
    for key, value in pairs(source) do
        target[key] = value
    end
end

function GetTagsSnapshot(obj)
    local ok, tags = pcall(function()
        return CollectionService:GetTags(obj)
    end)
    return ok and tags or {}
end

local function ObjectLooksWorthRecording(obj)
    if obj:IsA("ProximityPrompt") or obj:IsA("ValueBase") or obj:IsA("LuaSourceContainer") then
        return true
    end

    if IsNPCObject(obj) then
        return true
    end

    local attributes = GetAttributesSnapshot(obj)
    for key in pairs(attributes) do
        if KeyLooksLikeIdentifier(key) then
            return true
        end
    end

    local tags = GetTagsSnapshot(obj)
    return #tags > 0
end

local function ObjectLooksWorthWatching(obj)
    return ObjectLooksWorthRecording(obj) or NameLooksInteresting(obj.Name)
end

function IsNPCObject(obj)
    if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
        return true
    end

    local model = obj:FindFirstAncestorOfClass("Model")
    return model and model:FindFirstChildOfClass("Humanoid") and Players:GetPlayerFromCharacter(model) == nil
end

local function FindRelatedPrompt(obj)
    if obj:IsA("ProximityPrompt") then return obj end

    local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt then return prompt end

    local parent = obj.Parent
    if parent then
        return parent:FindFirstChildWhichIsA("ProximityPrompt", true)
    end

    return nil
end

local function BuildObjectSnapshot(obj)
    local name, decodeMethod = TryDecryptText(obj.Name)
    local prompt = FindRelatedPrompt(obj)
    local attributes = GetAttributesSnapshot(obj)
    local attributeIdentifiers = ExtractIdentifiersFromAttributes(attributes)
    local valueIdentifiers = ExtractIdentifiersFromValueObject(obj)
    local tags = GetTagsSnapshot(obj)
    local objectPath = GetObjectPath(obj)
    local parentPath = obj.Parent and GetObjectPath(obj.Parent) or nil
    local identifiers = attributeIdentifiers
    MergeIdentifiers(identifiers, ExtractIdentifiersFromText("Name", obj.Name))
    MergeIdentifiers(identifiers, ExtractIdentifiersFromText("Path", objectPath))

    local snapshot = {
        Name = name,
        RawName = obj.Name,
        DecodeMethod = decodeMethod,
        ClassName = obj.ClassName,
        Path = objectPath,
        Parent = parentPath,
        Tags = tags,
        Attributes = attributes,
        Identifiers = identifiers,
        IsNPC = IsNPCObject(obj),
    }

    if obj:IsA("ValueBase") then
        snapshot.Value = SerializeValue(obj.Value)
        for key, value in pairs(valueIdentifiers) do
            snapshot.Identifiers[key] = value
        end
    end

    if Config.IncludeObjectCoordinates then
        snapshot.Position = GetObjectPosition(obj)
    end

    if prompt then
        snapshot.Prompt = {
            Name = prompt.Name,
            ActionText = prompt.ActionText,
            ObjectText = prompt.ObjectText,
            Enabled = prompt.Enabled,
            HoldDuration = prompt.HoldDuration,
            MaxActivationDistance = prompt.MaxActivationDistance,
        }
    end

    if obj:IsA("LuaSourceContainer") then
        snapshot.ScriptLike = true
        snapshot.SourceReadable = false
        snapshot.Note = "Source de Script/LocalScript/ModuleScript nao fica disponivel para leitura normal em runtime."
    end

    return snapshot
end

local function AddObservableChange(changeType, obj, extra, forceRecord)
    if Config.DirectInteractionOnly and not forceRecord and not IsInsideObservableInteractionWindow() then return end
    if not obj then return end

    local ezzGui = LocalPlayer.PlayerGui:FindFirstChild("EZZ_Compact")
    if ezzGui and obj:IsDescendantOf(ezzGui) then return end

    if (changeType == "ADDED" or changeType == "REMOVED") and not ObjectLooksWorthRecording(obj) then
        return
    end

    if changeType == "ATTRIBUTE_CHANGED" and extra and extra.Attribute then
        if not KeyLooksLikeIdentifier(extra.Attribute) and not ObjectLooksWorthRecording(obj) then
            return
        end
    end

    ObservableChangeCount = ObservableChangeCount + 1
    if #RecordingData.Interactions.ObservableChanges >= Config.MaxObservableChanges then
        table.remove(RecordingData.Interactions.ObservableChanges, 1)
    end

    local entry = BuildObjectSnapshot(obj)
    entry.ID = ObservableChangeCount
    entry.Type = changeType
    entry.State = CurrentState
    entry.Time = os.date("%H:%M:%S")

    if extra then
        for key, value in pairs(extra) do
            entry[key] = SerializeValue(value)
        end
    end

    table.insert(RecordingData.Interactions.ObservableChanges, entry)
    RecordingData.Interactions.Summary.TotalObservableChanges = ObservableChangeCount
    AddToTimeline("OBSERVED_" .. changeType, {Name = entry.Name, ClassName = entry.ClassName})
end

local function AddWorldInteraction(interactionType, obj, extra)
    if not obj then return end

    local path = GetObjectPath(obj)
    local debounceParts = {interactionType, path}
    if extra and extra.Player then
        table.insert(debounceParts, extra.Player)
    end
    if ShouldDebounce(BuildDebounceKey("WORLD_" .. interactionType, debounceParts), Config.DebounceCooldown) then
        return
    end

    WorldInteractionCount = WorldInteractionCount + 1
    if #RecordingData.Interactions.WorldInteractions >= Config.MaxWorldInteractions then
        table.remove(RecordingData.Interactions.WorldInteractions, 1)
    end

    local entry = BuildObjectSnapshot(obj)
    entry.ID = WorldInteractionCount
    entry.Type = interactionType
    entry.Time = os.date("%H:%M:%S")
    entry.State = CurrentState

    if extra then
        for key, value in pairs(extra) do
            entry[key] = SerializeValue(value)
        end
    end

    table.insert(RecordingData.Interactions.WorldInteractions, entry)
    RecordingData.Interactions.Summary.TotalWorldInteractions = WorldInteractionCount
    AddToTimeline("WORLD_" .. interactionType, {Path = path, ClassName = obj.ClassName})
end

local function WatchValueObject(obj)
    if WatchedValueObjects[obj] or not obj:IsA("ValueBase") then return end
    if ValueWatchCount >= Config.MaxObservedValueWatches then return end
    if not ObjectLooksWorthWatching(obj) then return end

    ValueWatchCount = ValueWatchCount + 1
    WatchedValueObjects[obj] = SafeConnect(obj.Changed, function(newValue)
        AddObservableChange("VALUE_CHANGED", obj, { Value = newValue })
    end)
end

local function WatchAttributes(obj)
    if WatchedAttributeObjects[obj] then return end
    if AttributeWatchCount >= Config.MaxObservedAttributeWatches then return end
    if not ObjectLooksWorthWatching(obj) then return end

    local ok, connection = pcall(function()
        return SafeConnect(obj.AttributeChanged, function(attributeName)
            AddObservableChange("ATTRIBUTE_CHANGED", obj, {
                Attribute = attributeName,
                Value = obj:GetAttribute(attributeName)
            })
        end)
    end)

    if ok and connection then
        AttributeWatchCount = AttributeWatchCount + 1
        WatchedAttributeObjects[obj] = connection
    end
end

local function HookClickDetector(detector)
    if not Config.EnableClickDetectorMonitor or HookedClickDetectors[detector] then return end

    HookedClickDetectors[detector] = SafeConnect(detector.MouseClick, function(player)
        AddWorldInteraction("CLICK_DETECTOR", detector, {
            Player = player and player.Name or "Unknown"
        })
    end)
end

local function HookTouchInterest(touchInterest)
    if not Config.EnableTouchInterestMonitor then return end

    local part = touchInterest.Parent
    if not part or not part:IsA("BasePart") or HookedTouchParts[part] then return end

    HookedTouchParts[part] = SafeConnect(part.Touched, function(hit)
        local character = hit and hit:FindFirstAncestorOfClass("Model")
        local player = character and Players:GetPlayerFromCharacter(character)
        AddWorldInteraction("TOUCH_INTEREST", part, {
            Hit = hit and hit.Name or "Unknown",
            Player = player and player.Name or nil
        })
    end)
end

local function MonitorWorldInteractives()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("ClickDetector") then
            HookClickDetector(obj)
        elseif obj.Name == "TouchInterest" then
            HookTouchInterest(obj)
        end
    end
end

local function IsSuspiciousValueObject(obj)
    if not (obj:IsA("StringValue") or obj:IsA("NumberValue") or obj:IsA("IntValue")) then
        return false
    end

    local name = obj.Name:lower()
    return name:find("id", 1, true)
        or name:find("price", 1, true)
        or name:find("cost", 1, true)
        or name:find("value", 1, true)
        or name:find("amount", 1, true)
        or name:find("coin", 1, true)
        or name:find("gem", 1, true)
        or name:find("cash", 1, true)
end

local function MonitorPeriodicValueScan()
    if not Config.EnablePeriodicValueScan then return end

    task.spawn(function()
        while task.wait(Config.PeriodicValueScanInterval) do
            local recorded = 0
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if IsSuspiciousValueObject(obj) then
                    recorded = recorded + 1
                    if recorded > Config.MaxPeriodicScanResults then
                        break
                    end
                    AddObservableChange("PERIODIC_SCAN", obj, nil, true)
                end
            end
        end
    end)
end

local function DisconnectIfRemoved(connectionTable)
    for obj, connection in pairs(connectionTable) do
        if typeof(obj) ~= "Instance" or obj.Parent == nil then
            if connection then
                pcall(function()
                    connection:Disconnect()
                end)
            end
            connectionTable[obj] = nil
        end
    end
end

local function DisconnectContainerWatchersIfRemoved()
    for obj, connections in pairs(WatchedPlayerContainers) do
        if typeof(obj) ~= "Instance" or obj.Parent == nil then
            if type(connections) == "table" then
                for _, connection in pairs(connections) do
                    pcall(function()
                        connection:Disconnect()
                    end)
                end
            end
            WatchedPlayerContainers[obj] = nil
        end
    end
end

local function CleanupDebounceTable()
    local now = os.clock()
    for key, timestamp in pairs(DebounceTable) do
        if now - timestamp > 120 then
            DebounceTable[key] = nil
        end
    end
end

local function MonitorConnectionCleanup()
    task.spawn(function()
        while task.wait(60) do
            DisconnectIfRemoved(WatchedValueObjects)
            DisconnectIfRemoved(WatchedAttributeObjects)
            DisconnectIfRemoved(HookedClickDetectors)
            DisconnectIfRemoved(HookedTouchParts)
            DisconnectContainerWatchersIfRemoved()
            CleanupDebounceTable()
        end
    end)
end

local function MonitorObservableChanges()
    local roots = { Workspace, LocalPlayer.PlayerGui }

    for _, root in ipairs(roots) do
        for _, obj in ipairs(root:GetDescendants()) do
            WatchValueObject(obj)
            WatchAttributes(obj)
        end

        SafeConnect(root.DescendantAdded, function(obj)
            task.wait(0.05)
            WatchValueObject(obj)
            WatchAttributes(obj)
            if obj:IsA("ClickDetector") then
                HookClickDetector(obj)
            elseif obj.Name == "TouchInterest" then
                HookTouchInterest(obj)
            end
            AddObservableChange("ADDED", obj)
        end)

        SafeConnect(root.DescendantRemoving, function(obj)
            AddObservableChange("REMOVED", obj)
            if WatchedValueObjects[obj] then
                WatchedValueObjects[obj]:Disconnect()
                WatchedValueObjects[obj] = nil
                ValueWatchCount = math.max(0, ValueWatchCount - 1)
            end
            if WatchedAttributeObjects[obj] then
                WatchedAttributeObjects[obj]:Disconnect()
                WatchedAttributeObjects[obj] = nil
                AttributeWatchCount = math.max(0, AttributeWatchCount - 1)
            end
            if HookedClickDetectors[obj] then
                HookedClickDetectors[obj]:Disconnect()
                HookedClickDetectors[obj] = nil
            end
            if HookedTouchParts[obj] then
                HookedTouchParts[obj]:Disconnect()
                HookedTouchParts[obj] = nil
            end
        end)
    end
end

local CurrentCharacterWatcher = nil

local function IsPlayerContainerObject(obj)
    return obj:IsA("Tool")
        or obj:IsA("HopperBin")
        or obj:IsA("ValueBase")
        or obj:IsA("LuaSourceContainer")
        or NameLooksInteresting(obj.Name)
        or ObjectLooksWorthRecording(obj)
end

local function WatchPlayerContainer(container, label)
    if not container or WatchedPlayerContainers[container] then return end

    WatchedPlayerContainers[container] = {
        Added = SafeConnect(container.ChildAdded, function(obj)
            task.wait(0.05)
            WatchValueObject(obj)
            WatchAttributes(obj)

            local forceRecord = label == "Backpack" or label == "Character" or IsInsidePlayerContainerWindow()
            if IsPlayerContainerObject(obj) then
                AddObservableChange(label .. "_ADDED", obj, { Container = label }, forceRecord)
            end
        end),
        Removed = SafeConnect(container.ChildRemoved, function(obj)
            local forceRecord = label == "Backpack" or label == "Character" or IsInsidePlayerContainerWindow()
            if IsPlayerContainerObject(obj) then
                AddObservableChange(label .. "_REMOVED", obj, { Container = label }, forceRecord)
            end
        end)
    }

    for _, obj in ipairs(container:GetChildren()) do
        WatchValueObject(obj)
        WatchAttributes(obj)
    end
end

local function WatchCharacter(character)
    if CurrentCharacterWatcher then
        CurrentCharacterWatcher:Disconnect()
        CurrentCharacterWatcher = nil
    end

    WatchPlayerContainer(character, "Character")

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        CurrentCharacterWatcher = SafeConnect(humanoid.Died, function()
            AddObservableChange("CHARACTER_DIED", character, { Container = "Character" }, true)
        end)
    end
end

local function MonitorPlayerContainers()
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack") or LocalPlayer:WaitForChild("Backpack", 5)
    if backpack then
        WatchPlayerContainer(backpack, "Backpack")
    end

    if LocalPlayer.Character then
        WatchCharacter(LocalPlayer.Character)
    end

    SafeConnect(LocalPlayer.CharacterAdded, function(character)
        task.wait(0.2)
        WatchCharacter(character)
        AddObservableChange("CHARACTER_ADDED", character, { Container = "Character" }, true)
    end)
end

-- -----------------------------------------------------------
-- DETECTAR ESTADO
-- -----------------------------------------------------------
local function DetectGameState()
    if (os.clock() - LastStateDetectAt) < Config.StateDetectThrottle then
        return LastDetectedState ~= "UNKNOWN" and LastDetectedState or CurrentState
    end
    LastStateDetectAt = os.clock()

    local state = "UNKNOWN"
    local gui = LocalPlayer.PlayerGui
    local visibleTexts = {}

    for _, obj in pairs(gui:GetDescendants()) do
        local screenGui = obj:FindFirstAncestorWhichIsA("ScreenGui")
        if screenGui and screenGui.Name == "EZZ_Compact" then
            continue
        end

        if (obj:IsA("TextButton") or obj:IsA("TextLabel")) and obj.Visible then
            local text = obj.Text:upper()
            table.insert(visibleTexts, text)
            if text:find("PLAY") or text:find("JOGAR") then state = "MAIN_MENU" end
            if text:find("PRONTO") or text:find("READY") or text:find("SITE DE TRABALHO") then state = "LOBBY" end
        end
    end

    if Config.EnablePatternStateDetection then
        local bestState = state
        local bestScore = 0

        for candidateState, patterns in pairs(Config.StatePatterns) do
            local score = 0

            for _, uiPattern in ipairs(patterns.UI or {}) do
                local upperPattern = tostring(uiPattern):upper()
                for _, text in ipairs(visibleTexts) do
                    if text:find(upperPattern, 1, true) then
                        score = score + 1
                        break
                    end
                end
            end

            for _, workspacePattern in ipairs(patterns.Workspace or {}) do
                if Workspace:FindFirstChild(workspacePattern, true) then
                    score = score + 1
                end
            end

            if score > bestScore then
                bestScore = score
                bestState = candidateState
            end
        end

        if bestScore > 0 then
            state = bestState
        end
    elseif Workspace:FindFirstChild("Ghost") then
        state = "IN_GAME"
    end

    if state ~= CurrentState and state ~= "UNKNOWN" then
        AddToTimeline("STATE_CHANGE", {From = CurrentState, To = state})
        CurrentState = state
    end

    LastDetectedState = state
    return state
end

-- -----------------------------------------------------------
-- CAPTURA DO ESTADO ATUAL
-- -----------------------------------------------------------
function CaptureCurrentState()
    local state = DetectGameState()
    local ui = ScanImportantUI()
    local observed = RecordingData.Interactions.ObservableChanges

    if state == "MAIN_MENU" then
        RecordingData.GameStates.MainMenu.Captured = true
        RecordingData.GameStates.MainMenu.ImportantButtons = ui.Buttons
        RecordingData.GameStates.MainMenu.KeyElements = ui.Labels
        RecordingData.GameStates.MainMenu.ObservableChanges = observed
        Log("[OK] Menu capturado: " .. #ui.Buttons .. " botoes interagidos")
    elseif state == "LOBBY" then
        RecordingData.GameStates.Lobby.Captured = true
        RecordingData.GameStates.Lobby.MapButtons = ui.Buttons
        RecordingData.GameStates.Lobby.ObservableChanges = observed
        RecordingData.GameStates.Lobby.Players = {}
        for _, player in pairs(Players:GetPlayers()) do
            table.insert(RecordingData.GameStates.Lobby.Players, player.Name)
        end
        Log("[OK] Lobby capturado: " .. #ui.Buttons .. " botoes interagidos")
    elseif state == "IN_GAME" then
        RecordingData.GameStates.InGame.Captured = true
        local ghost = Workspace:FindFirstChild("Ghost")
        if ghost then
            RecordingData.GameStates.InGame.Ghost = {
                Name = ghost.Name,
                Type = ghost:GetAttribute("GhostType") or "Unknown"
            }
        end
        RecordingData.GameStates.InGame.ImportantItems = ui.Buttons
        RecordingData.GameStates.InGame.ObservableChanges = observed
        Log("[OK] Jogo capturado: " .. #ui.Buttons .. " itens interagidos")
    end

    AddToTimeline("CAPTURE", {State = state})
end

-- -----------------------------------------------------------
-- CAPTURA DE SCRIPTS / CODIGOS (sem remotes, por varredura direta)
-- -----------------------------------------------------------
-- Esta rotina NAO usa remote, nao executa codigo e nao tenta bypass.
-- Ela apenas tenta ler obj.Source diretamente via pcall quando o ambiente permite.
-- Se Source nao vier, salva metadata da instancia e uma nota explicando o limite.

local function LooksLikeLuaCode(text)
    if type(text) ~= "string" or text == "" then return false end
    local sample = text:sub(1, 2500)
    local patterns = {
        "local%s+[%w_]",
        "function%s*[%w_%.:]*%s*%(",
        "game:GetService%s*%(",
        "Instance%.new%s*%(",
        "script%.",
        "require%s*%(",
        "return%s+",
        "Enum%.",
        ":Connect%s*%(",
        "task%.",
    }
    for _, pattern in ipairs(patterns) do
        if sample:find(pattern) then
            return true
        end
    end
    return false
end

local function NormalizeWhitespacePreview(text, limit)
    limit = limit or Config.MaxScriptPreviewChars or 900
    if type(text) ~= "string" then return "" end
    local cleaned = text:gsub("\r\n", "\n"):gsub("\r", "\n")
    if #cleaned > limit then
        return cleaned:sub(1, limit) .. "\n...<preview_truncated>"
    end
    return cleaned
end

local function TruncateCapturedCode(text)
    if type(text) ~= "string" then return "" end
    local limit = Config.MaxCapturedCodeChars or 120000
    if #text <= limit then return text, false end
    return text:sub(1, limit) .. "\n...<code_truncated>", true
end

local function DetectSuspiciousCodePatterns(text)
    local flags = {}
    if type(text) ~= "string" or text == "" then return flags end
    local lower = text:lower()

    local checks = {
        { key = "loadstring", pattern = "loadstring%s*%(" },
        { key = "string_char_blob", pattern = "string%.char%s*%(" },
        { key = "bytecode_escape", pattern = "\\x%x%x" },
        { key = "environment_access", pattern = "getfenv%s*%(" },
        { key = "environment_write", pattern = "setfenv%s*%(" },
        { key = "debug_library", pattern = "debug%." },
        { key = "hidden_string_concat", pattern = "%.%.%s*string%.char" },
    }

    for _, check in ipairs(checks) do
        if lower:find(check.pattern) then
            table.insert(flags, check.key)
        end
    end

    local lineCount = 0
    for _ in text:gmatch("\n") do lineCount = lineCount + 1 end
    if #text > 4000 and lineCount <= 2 then
        table.insert(flags, "very_long_single_line")
    end

    return flags
end

-- Detecta se nome/path parecem codificados ou ofuscados.
local function AnalyzeScriptEncryption(name, path)
    local strongEncryptionPatterns = {
        "^[A-Za-z0-9+/]+=*$",           -- base64 puro no nome
        "^[0-9a-f]+$",                   -- hex puro
        "^[0-9]+$",                      -- decimal puro
        "^[_][_%w]+$",                   -- estilo __obf__
        "^[A-Z][a-zA-Z0-9]{20,}$",      -- nome muito longo sem separadores
    }
    local suspiciousPatterns = {
        "%d%d%d%d%d%d%d%d",
        "[_%$][_%$][_%$]",
        "[A-Z][A-Z][A-Z][A-Z][A-Z][A-Z]",
    }

    local testName = name or ""
    local testPath = path or ""

    for _, pattern in ipairs(strongEncryptionPatterns) do
        if testName:match(pattern) and #testName > 6 then
            return true, "nome_suspeito"
        end
    end

    for _, pattern in ipairs(suspiciousPatterns) do
        if testPath:match(pattern) or testName:match(pattern) then
            return "partial", "padrao_suspeito"
        end
    end

    local decoded, method = TryDecryptText(testName)
    if method ~= "plain" and decoded ~= testName then
        return true, method
    end

    return false, "plain"
end

local function ReadDirectSource(scriptObject)
    if not Config.EnableScriptSourceRead then
        return false, nil, "disabled"
    end

    local ok, result = pcall(function()
        return scriptObject.Source
    end)

    if ok and type(result) == "string" then
        return true, result, "Source"
    end

    return false, nil, tostring(result or "Source indisponivel neste ambiente")
end

local function AnalyzeCapturedCode(rawSource)
    local analysis = {
        SourceReadable = false,
        Code = nil,
        RawCode = nil,
        CodePreview = nil,
        CodeLength = 0,
        RawCodeLength = 0,
        CodeTruncated = false,
        DecodeMethod = "plain",
        Encrypted = false,
        SuspiciousFlags = {},
        LooksLikeCode = false,
    }

    if type(rawSource) ~= "string" then
        return analysis
    end

    analysis.SourceReadable = true
    analysis.RawCodeLength = #rawSource

    local decoded, method = TryDecryptText(rawSource)
    local finalCode = rawSource

    if method ~= "plain" and decoded and decoded ~= rawSource then
        finalCode = decoded
        analysis.RawCode = rawSource
        analysis.DecodeMethod = method
        analysis.Encrypted = true
    end

    local flags = DetectSuspiciousCodePatterns(finalCode)
    analysis.SuspiciousFlags = flags
    analysis.LooksLikeCode = LooksLikeLuaCode(finalCode)

    if analysis.Encrypted ~= true and #flags > 0 then
        analysis.Encrypted = "partial"
        if analysis.DecodeMethod == "plain" then
            analysis.DecodeMethod = "padrao_suspeito"
        end
    end

    local limitedCode, wasTruncated = TruncateCapturedCode(finalCode)
    analysis.Code = limitedCode
    analysis.CodeLength = #finalCode
    analysis.CodeTruncated = wasTruncated
    analysis.CodePreview = NormalizeWhitespacePreview(finalCode)

    return analysis
end

-- Varredura de scripts em uma raiz especifica.
local function ScanScriptsInRoot(root, sourceName, results, seen)
    local ok, descendants = pcall(function()
        return root:GetDescendants()
    end)
    if not ok then return end

    for _, obj in ipairs(descendants) do
        if obj:IsA("LuaSourceContainer") then
            local path = GetObjectPath(obj)

            if seen[path] then continue end
            seen[path] = true
            if #results >= Config.MaxCapturedScripts then break end

            local nameEncrypted, nameDecodeMethod = AnalyzeScriptEncryption(obj.Name, path)
            local sourceReadable, sourceText, sourceReadStatus = ReadDirectSource(obj)
            local codeAnalysis = AnalyzeCapturedCode(sourceText)

            local encrypted = codeAnalysis.Encrypted
            local decodeMethod = codeAnalysis.DecodeMethod

            if encrypted == false and nameEncrypted ~= false then
                encrypted = nameEncrypted
                decodeMethod = nameDecodeMethod
            elseif decodeMethod == "plain" and nameDecodeMethod ~= "plain" then
                decodeMethod = nameDecodeMethod
            end

            local note
            if sourceReadable then
                if codeAnalysis.Code and codeAnalysis.Code ~= "" then
                    if codeAnalysis.DecodeMethod ~= "plain" then
                        note = "Source lido diretamente e decodificado por " .. tostring(codeAnalysis.DecodeMethod) .. "."
                    else
                        note = "Source lido diretamente pelo ambiente atual."
                    end
                else
                    note = "Source lido, mas veio vazio."
                end
            else
                note = "Script encontrado como instancia; Source nao ficou disponivel para leitura direta neste ambiente."
            end

            local entry = {
                ID               = #results + 1,
                Name             = obj.Name,
                ClassName        = obj.ClassName,
                Path             = path,
                Source           = sourceName,
                SourceReadable   = sourceReadable,
                SourceReadStatus = sourceReadStatus,
                Code             = codeAnalysis.Code,
                RawCode          = codeAnalysis.RawCode,
                CodePreview      = codeAnalysis.CodePreview,
                CodeLength       = codeAnalysis.CodeLength,
                RawCodeLength    = codeAnalysis.RawCodeLength,
                CodeTruncated    = codeAnalysis.CodeTruncated,
                LooksLikeCode    = codeAnalysis.LooksLikeCode,
                SuspiciousFlags  = codeAnalysis.SuspiciousFlags,
                Encrypted        = encrypted,
                DecodeMethod     = decodeMethod,
                Enabled          = (obj:IsA("Script") or obj:IsA("LocalScript")) and obj.Enabled or nil,
                Note             = note,
                Time             = os.date("%H:%M:%S"),
                State            = CurrentState,
            }

            table.insert(results, entry)
        end
    end
end

-- Funcao principal: varre todos os locais acessiveis e retorna scripts/codigos capturados.
ScanScripts = function()
    local results = {}
    local seen = {}

    local roots = {
        { obj = Workspace, name = "Workspace" },
        { obj = LocalPlayer.PlayerGui, name = "PlayerGui" },
        { obj = game:GetService("ReplicatedStorage"), name = "ReplicatedStorage" },
