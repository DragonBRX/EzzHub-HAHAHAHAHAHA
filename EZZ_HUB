local function SerializeValue(value)
    local valueType = typeof(value)
    if valueType == "nil" or valueType == "number" or valueType == "string" or valueType == "boolean" then
        if (valueType == "number" or valueType == "string") and IsRobloxAssetID(value) then
            return {
                Value = value,
                PossibleRobloxAssetId = true
            }
        end
        return value
    end
    if valueType == "Instance" then
        return value:GetFullName()
    end
    if valueType == "Vector3" then
        if not Config.IncludeObjectCoordinates then return nil end
        return { X = value.X, Y = value.Y, Z = value.Z }
    end
    if valueType == "CFrame" then
        if not Config.IncludeObjectCoordinates then return nil end
        return tostring(value.Position)
    end
    if valueType == "Color3" then
        return { R = value.R, G = value.G, B = value.B }
    end
    return tostring(value)
end

local function SerializeRemoteArg(value, depth)
    depth = depth or 0
    if depth >= Config.MaxRemoteArgDepth then
        return "<max_depth>"
    end

    local valueType = typeof(value)
    if valueType == "string" then
        local trimmed = value:match("^%s*(.-)%s*$")
        if trimmed and (trimmed:sub(1, 1) == "{" or trimmed:sub(1, 1) == "[") then
            local ok, decoded = pcall(function()
                return HttpService:JSONDecode(trimmed)
            end)
            if ok then
                return {
                    __json = true,
                    Raw = value,
                    Data = SerializeRemoteArg(decoded, depth + 1)
                }
            end
        end
    end

    if valueType == "Instance" then
        local instanceSnapshot = {
            Type = "Instance",
            Name = value.Name,
            ClassName = value.ClassName,
            Path = GetObjectPath and GetObjectPath(value) or value.Name,
            Attributes = GetAttributesSnapshot and GetAttributesSnapshot(value) or {},
            Tags = GetTagsSnapshot and GetTagsSnapshot(value) or {},
        }

        if value:IsA("ValueBase") then
            instanceSnapshot.Value = SerializeValue(value.Value)
        end

        if value:IsA("LuaSourceContainer") then
            instanceSnapshot.ScriptLike = true
            instanceSnapshot.SourceReadable = false
            instanceSnapshot.Note = "Source nao fica disponivel para leitura normal em runtime."
        end

        return instanceSnapshot
    end

    if valueType == "table" then
        local output = {}
        local count = 0
        for key, nestedValue in pairs(value) do
            count = count + 1
            if count > Config.MaxRemoteArgs then
                output.__truncated = true
                break
            end
            output[tostring(key)] = SerializeRemoteArg(nestedValue, depth + 1)
        end
        return output
    end

    return SerializeValue(value)
end

local function SerializeRemoteArgs(args, argCount)
    local output = {}
    local totalArgs = argCount or #args
    for index = 1, math.min(totalArgs, Config.MaxRemoteArgs) do
        output[index] = SerializeRemoteArg(args[index], 0)
    end
    if totalArgs > Config.MaxRemoteArgs then
        output.Truncated = true
        output.TotalArgs = totalArgs
    end
    return output
end

local function TruncateString(value, maxLength)
    if type(value) ~= "string" then return value end
    if #value <= maxLength then return value end
    return value:sub(1, maxLength) .. "...<truncated>"
end

local function SerializeHttpPayload(value)
    if type(value) == "string" then
        local limited = TruncateString(value, Config.MaxHttpBodyChars)
        local trimmed = limited:match("^%s*(.-)%s*$")
        if trimmed and (trimmed:sub(1, 1) == "{" or trimmed:sub(1, 1) == "[") then
            local ok, decoded = pcall(function()
                return HttpService:JSONDecode(trimmed)
            end)
            if ok then
                return {
                    __json = true,
                    Raw = limited,
                    Data = SerializeRemoteArg(decoded, 0)
                }
            end
        end
        return limited
    end

    return SerializeRemoteArg(value, 0)
end

local function RegisterHttpCall(method, args, argCount, result)
    if not Config.EnableHttpHooks then return end

    HttpRequestCount = HttpRequestCount + 1
    if #RecordingData.Interactions.HttpRequests >= Config.MaxHttpCalls then
        table.remove(RecordingData.Interactions.HttpRequests, 1)
    end

    local url = nil
    local requestBody = nil
    local requestOptions = nil

    if method == "RequestAsync" and type(args[1]) == "table" then
        requestOptions = SerializeRemoteArg(args[1], 0)
        url = args[1].Url or args[1].url
        requestBody = args[1].Body or args[1].body
    else
        url = args[1]
        if method == "PostAsync" then
            requestBody = args[2]
        end
    end

    local entry = {
        ID = HttpRequestCount,
        Method = method,
        URL = tostring(url or ""),
        ArgCount = argCount,
        Request = requestOptions,
        RequestBody = SerializeHttpPayload(requestBody),
        Response = SerializeHttpPayload(result),
        Time = os.date("%H:%M:%S"),
        State = CurrentState
    }

    table.insert(RecordingData.Interactions.HttpRequests, entry)
    RecordingData.Interactions.Summary.TotalHttpRequests = HttpRequestCount
    AddToTimelineDebounced("HTTP_" .. method, {URL = entry.URL}, {entry.URL, method}, Config.DebounceCooldown)
end

local function BuildRemoteSummary(instance)
    local decodedName, decodeMethod = TryDecryptText(instance.Name)
    return {
        Name = decodedName,
        RawName = instance.Name,
        DecodeMethod = decodeMethod,
        ClassName = instance.ClassName,
        Path = GetObjectPath(instance),
        Attributes = GetAttributesSnapshot(instance),
        Tags = GetTagsSnapshot(instance),
    }
end

local function BuildRemoteTree(remote)
    local tree = {
        Parent = remote.Parent and BuildRemoteSummary(remote.Parent) or nil,
        Children = {},
        SiblingRemotes = {},
        NearbyRemoteDescendants = {},
    }

    local childCount = 0
    for _, child in ipairs(remote:GetChildren()) do
        childCount = childCount + 1
        if childCount > Config.MaxRemoteTreeItems then
            tree.ChildrenTruncated = true
            break
        end
        table.insert(tree.Children, BuildRemoteSummary(child))
    end

    if remote.Parent then
        local siblingCount = 0
        for _, sibling in ipairs(remote.Parent:GetChildren()) do
            if sibling ~= remote and (sibling:IsA("RemoteEvent") or sibling:IsA("RemoteFunction")) then
                siblingCount = siblingCount + 1
                if siblingCount > Config.MaxRemoteTreeItems then
                    tree.SiblingRemotesTruncated = true
                    break
                end
                table.insert(tree.SiblingRemotes, BuildRemoteSummary(sibling))
            end
        end

        local descendantCount = 0
        for _, descendant in ipairs(remote.Parent:GetDescendants()) do
            if descendant ~= remote and (descendant:IsA("RemoteEvent") or descendant:IsA("RemoteFunction")) then
                descendantCount = descendantCount + 1
                if descendantCount > Config.MaxRemoteTreeItems then
                    tree.NearbyRemoteDescendantsTruncated = true
                    break
                end
                table.insert(tree.NearbyRemoteDescendants, BuildRemoteSummary(descendant))
            end
        end
    end

    return tree
end

local function BuildValueSummary(valueObject)
    local decodedName, decodeMethod = TryDecryptText(valueObject.Name)
    return {
        Name = decodedName,
        RawName = valueObject.Name,
        DecodeMethod = decodeMethod,
        ClassName = valueObject.ClassName,
        Path = GetObjectPath(valueObject),
        Value = SerializeValue(valueObject.Value),
        Attributes = GetAttributesSnapshot(valueObject),
