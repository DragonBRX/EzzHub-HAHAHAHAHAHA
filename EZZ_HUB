local function CountTableEntries(source)
    local count = 0
    if type(source) ~= "table" then return 0 end
    for _ in pairs(source) do
        count = count + 1
    end
    return count
end

local function BuildFilteredResults()
    local filteredObjects = {}

    for _, entry in ipairs(RecordingData.Interactions.ObservableChanges) do
        local hasIdentifiers = CountTableEntries(entry.Identifiers) > 0
        local hasPrompt = entry.Prompt ~= nil
        local isUsefulObject = hasIdentifiers or hasPrompt or entry.IsNPC or entry.ScriptLike or entry.Type == "VALUE_CHANGED" or entry.Type == "ATTRIBUTE_CHANGED"

        if isUsefulObject then
            table.insert(filteredObjects, {
                Type = entry.Type,
                Name = entry.Name,
                ClassName = entry.ClassName,
                Path = entry.Path,
                Identifiers = entry.Identifiers,
                Attributes = entry.Attributes,
                Tags = entry.Tags,
                Value = entry.Value,
                Prompt = entry.Prompt,
                IsNPC = entry.IsNPC,
                ScriptLike = entry.ScriptLike,
                Note = entry.Note,
                Time = entry.Time,
                State = entry.State,
            })
        end
    end

    return {
        DirectClicks = RecordingData.Interactions.Clicks,
        RemoteCalls = RecordingData.Interactions.RemoteCalls,
        HttpRequests = RecordingData.Interactions.HttpRequests,
        WorldInteractions = RecordingData.Interactions.WorldInteractions,
        ChatCommands = RecordingData.Interactions.ChatCommands,
        UsefulObjects = filteredObjects,
        CapturedScripts = RecordingData.Interactions.CapturedScripts,
        Keys = PlayerInteractions.KeysPressed,
        Summary = {
            Clicks = #RecordingData.Interactions.Clicks,
            Remotes = #RecordingData.Interactions.RemoteCalls,
            HttpRequests = #RecordingData.Interactions.HttpRequests,
            WorldInteractions = #RecordingData.Interactions.WorldInteractions,
            ChatCommands = #RecordingData.Interactions.ChatCommands,
            UsefulObjects = #filteredObjects,
            ObservableChanges = #RecordingData.Interactions.ObservableChanges,
            Scripts = #RecordingData.Interactions.CapturedScripts,
        }
    }
end

function ExportJSON()
    RecordingData.SessionInfo.EndTime = os.time()
    RecordingData.SessionInfo.Duration = RecordingData.SessionInfo.EndTime - RecordingData.SessionInfo.StartTime
    RecordingData.FilteredResults = BuildFilteredResults()
    local json = HttpService:JSONEncode(RecordingData)
