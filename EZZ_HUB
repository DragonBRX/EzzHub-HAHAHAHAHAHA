-- -----------------------------------------------------------
local function Log(msg)
    print("[EZZ] " .. tostring(msg))
end

local function AddToTimeline(eventType, data)
    if #RecordingData.Timeline > 100 then
        table.remove(RecordingData.Timeline, 1)
    end
    table.insert(RecordingData.Timeline, {
        Time = os.time() - RecordingData.SessionInfo.StartTime,
        Type = eventType,
        Data = data
    })
end

local DebounceTable = {}

local function BuildDebounceKey(eventType, parts)
    local buffer = { tostring(eventType) }
    if type(parts) == "table" then
        for _, value in ipairs(parts) do
            table.insert(buffer, tostring(value))
        end
    end
    return table.concat(buffer, "|")
end

local function ShouldDebounce(key, cooldown)
    cooldown = cooldown or Config.DebounceCooldown
    local now = os.clock()
    if DebounceTable[key] and now - DebounceTable[key] < cooldown then
        return true
    end
    DebounceTable[key] = now
    return false
end

local function AddToTimelineDebounced(eventType, data, keyParts, cooldown)
    local key = BuildDebounceKey(eventType, keyParts)
    if ShouldDebounce(key, cooldown) then return end
    AddToTimeline(eventType, data)
end

local function SafeDefer(callback, ...)
    local args = {...}
    args.n = select("#", ...)
    task.defer(function()
        local ok, err = pcall(callback, table.unpack(args, 1, args.n))
        if not ok then
            Log("[ERROR] " .. tostring(err))
        end
    end)
end

local function SafeConnect(signal, callback)
    local ok, connection = pcall(function()
        return signal:Connect(function(...)
            local success, err = pcall(callback, ...)
            if not success then
                Log("[ERROR] " .. tostring(err))
            end
        end)
    end)
    if ok then return connection end
    Log("[ERROR] Falha ao conectar evento: " .. tostring(connection))
    return nil
end

-- -----------------------------------------------------------
-- DESCRIPTOGRAFIA / DECODIFICACAO DE TEXTOS CAPTURADOS
-- -----------------------------------------------------------
local Base64Chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

local function PadBase64(data)
    local remainder = #data % 4
    if remainder == 1 then return nil end
    if remainder == 2 then return data .. "==" end
    if remainder == 3 then return data .. "=" end
    return data
end

local function DecodeBase64(data)
    if type(data) ~= "string" or data == "" or data:find("[^A-Za-z0-9+/=]") then return nil end
    local padded = PadBase64(data)
    if not padded then return nil end
    local clean = padded:gsub("=", "")
    local bits = clean:gsub(".", function(char)
        local index = Base64Chars:find(char, 1, true)
        if not index then return "" end
        index = index - 1
        local chunk = ""
        for bit = 6, 1, -1 do
            chunk = chunk .. (index % 2 ^ bit - index % 2 ^ (bit - 1) > 0 and "1" or "0")
        end
        return chunk
    end)

    return bits:gsub("%d%d%d?%d?%d?%d?%d?%d?", function(byte)
        if #byte ~= 8 then return "" end
        local value = 0
        for i = 1, 8 do
            value = value + (byte:sub(i, i) == "1" and 2 ^ (8 - i) or 0)
        end
        return string.char(value)
    end)
end

local function DecodeBase64Url(data)
    if type(data) ~= "string" or data == "" or data:find("[^A-Za-z0-9_%-=]") then return nil end
    local normalized = data:gsub("-", "+"):gsub("_", "/")
    return DecodeBase64(normalized)
end

local function DecodeHex(data)
    if type(data) ~= "string" then return nil end
    local clean = data:gsub("\\x", ""):gsub("^0x", ""):gsub("[%s%-_:]", "")
    if #clean < 2 or #clean % 2 ~= 0 or clean:find("[^%x]") then return nil end
    return clean:gsub("%x%x", function(pair)
        return string.char(tonumber(pair, 16))
    end)
end

local function DecodeUrl(data)
    if type(data) ~= "string" or not data:find("%%") then return nil end
    return data:gsub("+", " "):gsub("%%u(%x%x%x%x)", function(hex)
        local codepoint = tonumber(hex, 16)
        if codepoint and codepoint <= 255 then
            return string.char(codepoint)
        end
        return ""
    end):gsub("%%(%x%x)", function(hex)
        return string.char(tonumber(hex, 16))
    end)
end

local function DecodeDecimalBytes(data)
    if type(data) ~= "string" then return nil end
    if not data:find("%d+[%s,;|]+%d+") then return nil end

    local bytes = {}
    for token in data:gmatch("%d+") do
        local value = tonumber(token)
        if not value or value < 0 or value > 255 then return nil end
        table.insert(bytes, string.char(value))
    end

    if #bytes < 2 then return nil end
    return table.concat(bytes)
end

local function DecodeRot13(data)
    if type(data) ~= "string" then return nil end
    local payload = data:match("^rot13:(.+)$") or data:match("^ROT13:(.+)$")
    if not payload or #payload < 4 or payload:find("[^%a%s_%-%.]") then return nil end
    return payload:gsub("%a", function(char)
        local base = char:lower() == char and string.byte("a") or string.byte("A")
        return string.char(((string.byte(char) - base + 13) % 26) + base)
    end)
end

local function LooksReadable(text)
    if type(text) ~= "string" or #text == 0 then return false end
    local printable = 0
    for i = 1, #text do
        local byte = text:byte(i)
        if byte == 9 or byte == 10 or byte == 13 or (byte >= 32 and byte <= 126) then
            printable = printable + 1
        end
    end
    return printable / #text >= 0.85
end

local function IsRobloxAssetID(value)
    local text = tostring(value)
    if not text:match("^%d+$") then return false end
    local number = tonumber(text)
    return number and number >= 10000000 and number <= 9999999999
end

local function TryDecryptText(value)
    if type(value) ~= "string" or value == "" then
        return value, "plain"
    end

    local methods = {
        { Name = "url", Decode = DecodeUrl },
        { Name = "hex", Decode = DecodeHex },
        { Name = "decimal_bytes", Decode = DecodeDecimalBytes },
        { Name = "base64", Decode = DecodeBase64 },
        { Name = "base64url", Decode = DecodeBase64Url },
        { Name = "rot13", Decode = DecodeRot13 },
    }

    for _, method in ipairs(methods) do
        local ok, decoded = pcall(method.Decode, value)
        if ok and decoded and decoded ~= value and LooksReadable(decoded) then
            return decoded, method.Name
        end
    end

    return value, "plain"
end

